# Copy this file to .env and fill in your Azure SQL credentials.
# .env is git-ignored and should NEVER be committed.

# Azure SQL Server (do NOT include tcp: prefix or port here)
# Example: mypaceserver.database.windows.net
DB_SERVER=your-server.database.windows.net

DB_DATABASE=your_database_name
DB_USERNAME=your_sql_username
DB_PASSWORD=your_sql_password

# Leave as-is unless you have ODBC Driver 17 installed
DB_DRIVER=ODBC Driver 18 for SQL Server
