# .streamlit/secrets.toml.example
# ─────────────────────────────────────────────────────────────────
# Copy this file to .streamlit/secrets.toml and fill in real values.
# secrets.toml is git-ignored and should NEVER be committed to Git.
#
# FOR LOCAL USE:
#   1. cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#   2. Fill in your username and password below
#   3. Run: streamlit run app.py
#
# FOR STREAMLIT CLOUD:
#   Do NOT upload this file. Instead paste these key/value pairs into:
#   share.streamlit.io → your app → Settings → Secrets
# ─────────────────────────────────────────────────────────────────

[azure_sql]
server   = "essql1.database.windows.net"
database = "ISYS43603_Spring2026_Sec02_Alice_db"
username = "your_username"
password = "your_password"
