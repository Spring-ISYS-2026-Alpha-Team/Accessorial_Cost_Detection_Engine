# .streamlit/secrets.toml.example
# ─────────────────────────────────────────────────────────────────
# FOR LOCAL USE:
#   Copy this file to .streamlit/secrets.toml and fill in values.
#   secrets.toml is git-ignored and should NEVER be committed.
#
# FOR STREAMLIT CLOUD:
#   Do NOT upload this file. Instead paste these values into:
#   share.streamlit.io → your app → Settings → Secrets
# ─────────────────────────────────────────────────────────────────

[azure_sql]
DB_SERVER   = "your-server.database.windows.net"
DB_DATABASE = "your_database_name"
DB_USERNAME = "your_sql_username"
DB_PASSWORD = "your_sql_password"
DB_DRIVER   = "ODBC Driver 18 for SQL Server"
